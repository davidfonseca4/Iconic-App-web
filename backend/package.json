{
  "name": "iconic-backend",
  "version": "1.0.0",
  "description": "Backend API for Iconic Store",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --transpile-only src/scripts/seedProducts.ts",
    "start:docker": "node dist/server.js"
  },
  "keywords": [
    "express",
    "typescript",
    "mysql",
    "iconic"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.7.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.23",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
